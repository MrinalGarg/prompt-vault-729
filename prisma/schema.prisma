generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = "postgresql://user@localhost:5432/viadb?schema=public"
}

model PromptSection {
  id          Int      @id @default(autoincrement())
  slug        String   @unique
  title       String
  summary     String
  body        String
  emphasis    String
  order       Int
  createdAt   DateTime @default(now())
}
